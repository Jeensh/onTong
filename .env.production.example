# ======================
# onTong Production Environment
# ======================
# Copy to .env and fill in values before running docker compose up

# LLM — Ollama local (air-gap default)
LITELLM_MODEL=ollama/llama3
OLLAMA_HOST=http://host.docker.internal:11434

# Embedding — ChromaDB built-in (no external API)
EMBEDDING_PROVIDER=default

# Storage
STORAGE_BACKEND=local
WIKI_DIR=/app/wiki
# For NAS mount:
# STORAGE_BACKEND=nas
# NAS_WIKI_DIR=/mnt/nas/ontong/wiki

# ChromaDB (internal docker network)
CHROMADB_HOST=chroma
CHROMADB_PORT=8000
CHROMADB_COLLECTION=ontong_wiki

# Application
ENVIRONMENT=production
LOG_LEVEL=INFO
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8001
FRONTEND_URL=http://frontend:3000

# Auth
AUTH_PROVIDER=noop

# Search
ENABLE_RERANKER=true

# Monitoring (optional — run with: docker compose --profile monitoring up)
ENABLE_LANGFUSE_MONITOR=false
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
