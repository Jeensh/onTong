# ======================
# LLM Configuration
# ======================
# Default: Ollama local model (air-gap safe, no API key needed)
LITELLM_MODEL=ollama/llama3
OLLAMA_HOST=http://localhost:11434

# Optional: Cloud LLM (requires internet access)
# LITELLM_MODEL=openai/gpt-4o-mini
# LITELLM_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-claude-key

# ======================
# Embedding Configuration
# ======================
# "default" = ChromaDB built-in (all-MiniLM-L6-v2, no API needed)
# "openai"  = OpenAI text-embedding-3-small (requires OPENAI_API_KEY)
EMBEDDING_PROVIDER=default
# OPENAI_API_KEY=sk-your-key

# ======================
# Storage Configuration
# ======================
# "local" = local filesystem, "nas" = NAS mount path
STORAGE_BACKEND=local
WIKI_DIR=wiki

# NAS mount path (only used when STORAGE_BACKEND=nas)
# NAS_WIKI_DIR=/mnt/nas/ontong/wiki

# ======================
# ChromaDB (Vector Database)
# ======================
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_COLLECTION=ontong_wiki

# ======================
# Langfuse (LLM Monitoring)
# ======================
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
ENABLE_LANGFUSE_MONITOR=false

# PostgreSQL (for Langfuse)
DATABASE_URL=postgresql://langfuse:langfuse_dev@localhost:5432/langfuse

# ======================
# Application
# ======================
ENVIRONMENT=development
LOG_LEVEL=INFO

# FastAPI
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Monitoring
LOG_DIR=.logs
ENABLE_LOCAL_MONITOR=true

# Auth
AUTH_PROVIDER=noop

# Search
ENABLE_RERANKER=true
